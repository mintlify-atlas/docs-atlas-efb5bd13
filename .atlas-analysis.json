  "keyFeatures": [
    "JWT-based authentication with email verification",
    "Role-based access control (USER_ROLE, ADMIN_ROLE)",
    "Bank account management (AHORRO, MONETARIA)",
    "Secure transactions with daily limits and validation",
    "Points-based rewards system for service redemption",
    "Automated interest calculation for savings accounts",
    "Account request approval workflow",
    "Currency conversion support (GTQ to USD)",
    "Rate limiting and security middleware",
    "Email notifications for verification and transactions",
    "Profile picture upload with Cloudinary integration",
    "Transaction history and account favorites"
  ],
